{
  "name": "datadog-cli-ts",
  "version": "0.1.1",
  "description": "TypeScript CLI wrapper for Datadog API — logs, traces, events, monitors with OAuth2 & API key auth",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/demarlik01/datadog-cli-ts.git"
  },
  "keywords": [
    "datadog",
    "cli",
    "apm",
    "traces",
    "logs",
    "monitors",
    "observability",
    "typescript"
  ],
  "bin": {
    "dd-cli": "dist/dd-cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "README-ko.md"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"require('fs').chmodSync('dist/dd-cli.js',0o755)\"",
    "dev": "tsx bin/dd-cli.ts",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@datadog/datadog-api-client": "^1.53.0",
    "commander": "^14.0.1",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  }
}
